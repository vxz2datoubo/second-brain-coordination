{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.second-brain.local/foundation/shared-envelope/1.0.0",
  "title": "Foundation Shared Envelope",
  "type": "object",
  "required": ["object_id", "schema_version", "producer", "run_id", "trace_id", "status", "created_at", "lineage"],
  "properties": {
    "object_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.:-]{2,127}$"},
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "producer": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "pattern": "^[a-zA-Z0-9_.:-]{3,128}$"},
    "trace_id": {"type": "string", "pattern": "^[a-zA-Z0-9_.:-]{3,128}$"},
    "status": {"enum": ["candidate", "approved", "rejected", "superseded", "quarantined", "experimental", "active"]},
    "created_at": {"type": "string", "format": "date-time"},
    "lineage": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["kind", "reference"], "properties": {"kind": {"enum": ["source", "artifact", "dataset", "contract", "decision"]}, "reference": {"type": "string", "minLength": 1}}, "additionalProperties": true}}
  },
  "additionalProperties": true
}
