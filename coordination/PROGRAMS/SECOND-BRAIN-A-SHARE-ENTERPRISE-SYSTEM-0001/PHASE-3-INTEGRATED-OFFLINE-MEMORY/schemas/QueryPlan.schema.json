{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:superbrain:p3:QueryPlan:1.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["query_text", "scopes", "atom_types", "truth_states", "source_manifest_ids", "evidence_qualities", "query_aliases", "min_confidence", "include_conflicts", "include_unknowns", "include_revoked_sources", "history_mode", "relation_depth", "budget", "schema_version"],
  "properties": {
    "query_text": {"type": "string"},
    "scopes": {"type": "array"},
    "atom_types": {"type": "array"},
    "truth_states": {"type": "array", "minItems": 1},
    "source_manifest_ids": {"type": "array"},
    "evidence_qualities": {"type": "array"},
    "query_aliases": {"type": "array"},
    "min_confidence": {"type": "number", "minimum": 0},
    "time_start": {"type": ["string", "null"]},
    "time_end": {"type": ["string", "null"]},
    "include_conflicts": {"type": "boolean"},
    "include_unknowns": {"type": "boolean"},
    "include_revoked_sources": {"type": "boolean"},
    "history_mode": {"type": "string", "enum": ["CURRENT", "HISTORY"]},
    "relation_depth": {"type": "integer", "minimum": 0},
    "budget": {"type": "integer", "minimum": 1},
    "schema_version": {"type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$"}
  }
}
