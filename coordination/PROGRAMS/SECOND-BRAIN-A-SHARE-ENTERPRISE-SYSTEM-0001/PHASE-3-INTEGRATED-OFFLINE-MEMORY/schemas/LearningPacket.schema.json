{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:superbrain:p3:LearningPacket:1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packet_id", "packet_content_hash", "idempotency_key", "status", "authority_write", "no_trade_gate", "processor_version", "base_knowledge_version", "source_manifest_ids", "source_hash", "validation_report", "evidence_refs", "atoms", "relations", "unknowns", "conflicts"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$"},
    "packet_id": {"type": "string", "minLength": 1},
    "packet_content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "idempotency_key": {"type": "string", "minLength": 1},
    "status": {"const": "candidate"},
    "authority_write": {"const": false},
    "no_trade_gate": {"const": true},
    "processor_version": {"type": "string"},
    "base_knowledge_version": {"type": "string"},
    "source_manifest_ids": {"type": "array", "minItems": 1},
    "source_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "validation_report": {"type": "object"},
    "evidence_refs": {"type": "array", "minItems": 1},
    "atoms": {"type": "array"},
    "relations": {"type": "array"},
    "unknowns": {"type": "array"},
    "conflicts": {"type": "array"}
  }
}
