{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:superbrain:p4:KnowledgeSourceManifest:1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_id", "source_id", "source_version", "source_kind", "local_reference", "owner_authorization", "license_status", "privacy_class", "content_category", "allowed_formats", "source_time_semantics", "gpt_access", "transport_visibility", "authority_level", "revocable", "read_only", "schema_version"],
  "properties": {
    "manifest_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_version": {"type": "string", "minLength": 1},
    "source_kind": {"type": "string", "enum": ["FILE", "DIRECTORY", "EXISTING_SERVICE"]},
    "local_reference": {"type": "object"},
    "owner_authorization": {"type": "string", "enum": ["USER_AUTHORIZED", "PUBLIC", "LICENSED"]},
    "license_status": {"type": "string"},
    "privacy_class": {"type": "string", "enum": ["PUBLIC_SAFE", "PRIVATE_LOCAL_ONLY", "LICENSED_LOCAL"]},
    "content_category": {"type": "string", "minLength": 1},
    "allowed_formats": {"type": "array", "minItems": 1},
    "source_time_semantics": {"type": "string", "minLength": 1},
    "gpt_access": {"const": "FULL_SEMANTIC_ACCESS"},
    "transport_visibility": {"type": "string", "enum": ["PUBLIC_SAFE_BODY", "PRIVATE_LOCAL_ONLY"]},
    "authority_level": {"const": "CANDIDATE_ONLY"},
    "revocable": {"const": true},
    "read_only": {"const": true},
    "schema_version": {"type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$"}
  }
}
