{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IntegratedFlowReceipt.schema.json",
  "title": "IntegratedFlowReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "trace_id",
    "packet_id",
    "packet_content_hash",
    "idempotency_key",
    "import_status",
    "knowledge_version",
    "query_plan_hash",
    "context_bundle_hash",
    "retrieved_atom_ids",
    "unknown_ids",
    "source_lineage",
    "research_only",
    "no_trade_gate",
    "authority_write",
    "raw_records_exported"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "run_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "packet_id": {"type": "string"},
    "packet_content_hash": {"type": "string"},
    "idempotency_key": {"type": "string"},
    "import_status": {"type": "string", "enum": ["IMPORTED", "IDEMPOTENT_DUPLICATE"]},
    "knowledge_version": {"type": "string"},
    "query_plan_hash": {"type": "string"},
    "context_bundle_hash": {"type": "string"},
    "retrieved_atom_ids": {"type": "array", "items": {"type": "string"}},
    "unknown_ids": {"type": "array", "items": {"type": "string"}},
    "source_lineage": {"type": "array", "items": {"type": "string"}},
    "research_only": {"type": "boolean", "const": true},
    "no_trade_gate": {"type": "boolean", "const": true},
    "authority_write": {"type": "boolean", "const": false},
    "raw_records_exported": {"type": "boolean", "const": false}
  }
}
