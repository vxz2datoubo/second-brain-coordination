{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://second-brain/qclaw/schemas/secret-scan-receipt-v1",
  "title": "Secret Scan Receipt",
  "description": "Proof that secret scanning was performed on a source. Records findings without containing actual secret values.",
  "type": "object",
  "required": [
    "receipt_id", "source_id", "source_hash",
    "scan_timestamp", "scan_tool", "result",
    "secrets_found", "redaction_applied"
  ],
  "properties": {
    "receipt_id": {"type": "string", "pattern": "^SCR-[A-Fa-f0-9]{8}$"},
    "source_id": {"type": "string", "pattern": "^SRC-[A-Fa-f0-9]{8}$"},
    "source_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "scan_timestamp": {"type": "string", "format": "date-time"},
    "scan_tool": {"type": "string"},
    "scan_version": {"type": "string"},
    "result": {
      "type": "string",
      "enum": ["CLEAN", "SECRETS_FOUND_AND_REDACTED", "SECRETS_FOUND_PARTIALLY_REDACTED", "SCAN_ERROR", "SCAN_SKIPPED_FORMAT_UNSUPPORTED"]
    },
    "secrets_found": {"type": "integer", "minimum": 0},
    "secret_types_found": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "API_KEY", "TOKEN", "PASSWORD", "PRIVATE_KEY",
          "CERTIFICATE", "CREDENTIAL_FILE", "CONNECTION_STRING",
          "SESSION_COOKIE", "OAUTH_SECRET", "WEBHOOK_SECRET",
          "ENCRYPTION_KEY", "DATABASE_CREDENTIAL",
          "FINANCIAL_ACCOUNT", "BROKER_API_KEY",
          "PAYMENT_PROCESSOR_KEY", "CRYPTOCURRENCY_KEY",
          "PERSONAL_IDENTIFIER", "UNKNOWN"
        ]
      }
    },
    "redaction_positions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "position_type": {"type": "string", "enum": ["LINE", "CHAR_RANGE", "FIELD_PATH", "JSON_PATH"]},
          "location": {"type": "string"},
          "secret_type": {"type": "string"},
          "redaction_method": {"type": "string", "enum": ["REMOVED", "REPLACED_WITH_PLACEHOLDER", "HASHED"]}
        }
      }
    },
    "redaction_applied": {"type": "boolean"},
    "redaction_method": {"type": "string"},
    "hash_after_redaction": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "semantic_damage_assessment": {
      "type": "string",
      "enum": ["NONE", "MINIMAL", "MODERATE", "SIGNIFICANT", "CRITICAL"],
      "description": "How much semantic knowledge was lost due to redaction."
    },
    "semantic_damage_description": {"type": "string", "maxLength": 500},
    "verification_checksum": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "digest_run_id": {"type": "string", "pattern": "^DIG-[A-Fa-f0-9]{8}$"},
    "notes": {"type": "string", "maxLength": 1000}
  },
  "additionalProperties": false
}
